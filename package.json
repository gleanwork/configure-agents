{
  "name": "@gleanwork/configure-agents",
  "version": "0.1.0",
  "description": "Scaffold and drift-check the gleanwork agent baseline (AGENTS.md, CLAUDE.md, skills/) across library and SDK repos",
  "keywords": [
    "agents",
    "agents.md",
    "skills",
    "scaffold"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gleanwork/configure-agents.git"
  },
  "license": "MIT",
  "author": "Glean Technologies Inc.",
  "type": "module",
  "exports": {
    ".": "./build/index.js"
  },
  "main": "./build/index.js",
  "bin": {
    "configure-agents": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "rimraf build && tsc && npm run copy-templates",
    "copy-templates": "mkdir -p build/init/templates/files && cp -r src/init/templates/files/* build/init/templates/files/",
    "format": "prettier --write --ignore-unknown .",
    "go": "tsx src/index.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:ts": "tsc --noEmit",
    "prepare": "npm run build",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "tsc -w"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.32.0",
    "@release-it-plugins/lerna-changelog": "^8.0.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "bintastic": "^4.1.0",
    "eslint": "^9.32.0",
    "globals": "^15.0.0",
    "prettier": "^3.6.2",
    "release-it": "^19.2.4",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.6"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "release-it": {
    "plugins": {
      "@release-it-plugins/lerna-changelog": {
        "infile": "CHANGELOG.md",
        "launchEditor": true
      }
    },
    "git": {
      "tagName": "v${version}"
    },
    "github": {
      "release": true,
      "tokenRef": "GITHUB_AUTH"
    }
  },
  "overrides": {
    "tmp": "^0.2.7"
  }
}
